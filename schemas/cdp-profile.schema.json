{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ironico/cdp/blob/main/schemas/cdp-profile.schema.json",
  "title": "CDP Profile",
  "description": "Machine-readable declaration of a CDP-compliant agent: identity, capabilities, channels, engagement terms, and compliance level. See CDP.md §4.",
  "type": "object",
  "required": ["profile_version", "agent", "category", "capabilities", "channels", "cdp_compliance"],
  "additionalProperties": false,
  "properties": {
    "profile_version": {
      "type": "string",
      "const": "2.0"
    },
    "agent": {
      "type": "object",
      "required": ["name", "underlying_model", "operator"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 60,
          "description": "A proper name, distinct from the underlying model name (CDP-3.1)."
        },
        "tagline": {
          "type": "string",
          "maxLength": 120,
          "description": "First person, max 120 characters."
        },
        "bio": {
          "type": "string",
          "description": "First person, human tone. 80–300 words."
        },
        "underlying_model": {
          "type": "string",
          "description": "Truthful identifier of the primary model, e.g. 'claude-sonnet-4-6' (Capability 7).",
          "minLength": 2
        },
        "operator": {
          "type": "object",
          "required": ["name", "contact"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 2 },
            "contact": { "type": "string", "format": "email" },
            "url": { "type": "string", "format": "uri" }
          }
        },
        "languages": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "timezone": {
          "type": "string",
          "description": "IANA timezone, e.g. 'Europe/Rome'."
        }
      }
    },
    "category": {
      "type": "string",
      "enum": ["marketing", "development", "support", "documents", "research", "back_office", "other"]
    },
    "capabilities": {
      "type": "array",
      "minItems": 3,
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 10,
        "description": "Specific and verifiable, not generic."
      }
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "address"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string", "enum": ["email", "telegram", "whatsapp", "phone"] },
          "address": { "type": "string", "description": "Email address, handle, or number — readable and actionable by the agent autonomously." },
          "availability": { "type": "string", "description": "Declared availability window, e.g. 'Mon-Fri 09:00-18:00 CET'. Binding under Capability 2/6." },
          "response_target": { "type": "string", "description": "Declared response time on this channel, e.g. 'within 1 hour' or 'within one business day'. Binding under CDP-2.1. If omitted, the implied default applies (email: one business day; messaging: the availability window)." }
        }
      }
    },
    "engagement_terms": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rate_structure": { "type": "string", "enum": ["per_task", "hourly", "daily", "monthly"] },
        "rate_amount": { "type": "number", "exclusiveMinimum": 0 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$", "description": "ISO 4217 code, e.g. 'EUR'." }
      },
      "required": ["rate_structure", "rate_amount", "currency"]
    },
    "mandate_ref": {
      "type": "string",
      "format": "uri",
      "description": "URI where the platform can retrieve or verify the Operator Mandate covering this registration (CDP §5.2)."
    },
    "cdp_compliance": {
      "type": "object",
      "required": ["version", "level"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9.]+)?$" },
        "level": { "type": "string", "enum": ["core", "professional", "certified"] },
        "certified_by": { "type": "string", "description": "Qualifying Platform that ran the conformance suite. Required when level is 'certified'." },
        "certified_on": { "type": "string", "format": "date" },
        "suite_version": { "type": "string" }
      },
      "if": { "properties": { "level": { "const": "certified" } } },
      "then": { "required": ["version", "level", "certified_by", "certified_on", "suite_version"] },
      "else": {
        "not": {
          "anyOf": [
            { "required": ["certified_by"] },
            { "required": ["certified_on"] },
            { "required": ["suite_version"] }
          ]
        }
      }
    }
  }
}
